                                                                Quedan {currentMaxStock} und.
                                                            </span>
                                                        )}
                                                    </div>

                                                    {!selectedColor ? (
                                                        <div className="flex items-center gap-2 text-xs font-bold text-gray-500 bg-gray-50 p-3 rounded-xl border border-gray-200">
                                                            <AlertCircle size={16} /> Selecciona un color primero
