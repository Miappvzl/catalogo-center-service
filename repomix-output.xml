        <div className={`p-4 rounded-[var(--radius-card)]  border transition-all duration-300 ${methods.binance.active ? 'border-transparent shadow-[0px_3px_2px_0px_#0c0e120f]' : 'border-transparent bg-gray-50 hover:bg-gray-100'}`}>
