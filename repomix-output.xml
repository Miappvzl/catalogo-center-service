        {/* BINANCE */}
        <div className={`p-4 rounded-xl border transition-all duration-300 ${methods.binance.active ? 'border-yellow-300 bg-yellow-50/50' : 'border-gray-200 bg-white'}`}>
          <div className="flex justify-between items-center mb-3">
