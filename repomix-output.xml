}

// --- LOGOS DE MÉTODOS DE PAGO ---
const BrandLogos = {
    Zelle: ({ className, size }: any) => (
        <svg viewBox="0 0 24 24" fill="currentColor" className={className} style={{ width: size, height: size }}>
