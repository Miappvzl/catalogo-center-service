    storeConfig: any;
    currency: 'usd' | 'eur';
    rates: { usd: number, eur: number };
    phone: string;
    cartEngine: any;
    wholesaleDiscountList: number;
    wholesaleDiscountCash: number;
    onSuccess: (orderNumber: number, whatsappUrl: string) => void;
